[node name="Tutorial" type="Node2D" unique_id=987998091]
editor_description = "Welcome to the tutorial scene. It is for now a sample scene with some helpful tips. Hover over the various nodes for additional help."

[node name="Body1" type="StaticBody2D" parent="." unique_id=2042129562]
editor_description = "Tips:
1. Duplicate this node to create another terrain segment. Remember to rename the child Terrain[n]_CollisionPolygon2D and Terrain[n] nodes with the new number and change the Collision Polygon Node Path (under the Collision category of the Terrain node) to the newly created CollisionPolygon2D
2. Change the Material property under the Materials category of the Terrain[n] node to res://assets/ss2d_materials/wood.tres for the wood material."

